# Rev-Agent Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Listener Configuration
# =============================================================================

# Port for the proxy server (default: 8080)
REV_AGENT_PORT=8080

# Host to bind (default: 0.0.0.0)
REV_AGENT_HOST=0.0.0.0

# =============================================================================
# API Configuration
# =============================================================================

# Backend API base URL (OpenAI-compatible format, required)
# The proxy converts Anthropic format to OpenAI format and forwards to this URL
# Examples:
#   - https://api.openai.com/v1
#   - https://api.deepseek.com/v1
#   - Your custom OpenAI-compatible API endpoint
OPENAI_BASE_URL=https://api.deepseek.com/v1

# =============================================================================
# Proxy Configuration (optional)
# =============================================================================

# HTTP proxy for API requests (leave empty to disable)
# HTTP_PROXY=http://127.0.0.1:7897

# =============================================================================
# Storage Configuration
# =============================================================================

# Directory for storing session logs (default: logs)
REV_AGENT_LOGS_DIR=logs
